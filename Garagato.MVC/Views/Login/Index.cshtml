@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="h-full flex justify-center items-center">
    <div class="p-10 shadow-lg rounded-lg w-[90%] md:w-[70%] lg:w-[40%] bg-white">
        <h2 class="text-2xl font-bold text-center mb-2 text-dark">¡Bienvenido!</h2>
        <form asp-action="Login" method="post" class="flex flex-col gap-4">
            <div asp-validation-summary="ModelOnly" class="text-red-500 mb-4"></div>
            <div class="flex flex-col">
                <label asp-for="Nombre" class="text-gray-700 mb-1">Nombre de usuario: </label>
                <input asp-for="Nombre" class="border border-gray-500 p-2 rounded focus:outline-none focus:ring-2 focus:ring-red-500">
                <span asp-validation-for="Nombre" class="text-red-500"></span>
            </div>
            <div class="flex flex-col">
                <label asp-for="Contrasena" class="text-gray-700 mb-1">Contraseña: </label>
                <input asp-for="Contrasena" type="password" class="border border-gray-500 p-2 rounded focus:outline-none focus:ring-2 focus:ring-red-500">
                <span asp-validation-for="Contrasena" class="text-red-500"></span>
            </div>
            <button type="submit" class="bg-secondary font-semibold text-white py-2 px-4 rounded hover:border-[#2E294E] hover:bg-[#F46036] hover:text-white">Iniciar Sesión</button>
        </form>
        <a href="/register/index" class="text-secondary font-semibold py-2 px-4 mt-4 w-full rounded text-center block border-2 border-[#D7263D] hover:border-[#F46036] hover:bg-[#F46036] hover:text-white">
            Registrarse
        </a>
        <div >
            <div>
                <a href="@Url.Action("Inicio", "Login")" class="flex items-center justify-center text-secondary font-semibold py-2 px-4 mt-4 w-full rounded text-center block border-2 border-[#D7263D] hover:border-[#F46036] hover:bg-[#F46036] hover:text-white">
                    <span class="mr-2">Iniciar Sesión con Google</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-google" viewBox="0 0 16 16">
                        <path d="M15.545 6.558a9.4 9.4 0 0 1 .139 1.626c0 2.434-.87 4.492-2.384 5.885h.002C11.978 15.292 10.158 16 8 16A8 8 0 1 1 8 0a7.7 7.7 0 0 1 5.352 2.082l-2.284 2.284A4.35 4.35 0 0 0 8 3.166c-2.087 0-3.86 1.408-4.492 3.304a4.8 4.8 0 0 0 0 3.063h.003c.635 1.893 2.405 3.301 4.492 3.301 1.078 0 2.004-.276 2.722-.764h-.003a3.7 3.7 0 0 0 1.599-2.431H8v-3.08z" />
                    </svg>
                </a>
            </div>
    </div>

</div>
